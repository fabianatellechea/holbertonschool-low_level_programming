#include "3-calc.h"
#include <stdio.h>

/**
  *op_add - add
  *@a: int1
  *@b: int2
  *Return: a + b
  */

int op_add(int a, int b)
{
	return (a + b);
}

/**
  *op_sub - sub
  *@a: int1
  *@b: int2
  *Return: a - b
  */

int op_sub(int a, int b)
{
	return (a - b);
}

/**
  *op_mul - mul
  *@a: int1
  *@b: int2
  *Return: a *b
  */

int op_mul(int a, int b)
{
	return (a * b);
}

/**
  *op_div - div
  *@a: int1
  *@b: int2
  *Return: a / b
  */

int op_div(int a, int b)
{

	return (a / b);

	if (b == 0)

	printf("Error\n");
	exit(100);
}

/**
  *op_mod - mod
  *@a: int1
  *@b: int2
  *Return: a % b
  */

int op_mod(int a, int b)
{
	return (a % b);

	if (b == 0)

	printf("Error\n");
	exit(100);
}
